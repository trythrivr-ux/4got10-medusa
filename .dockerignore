# Exclude everything by default
*

# Only include medusa-backend
!medusa-backend/

# Exclude large/unnecessary files inside medusa-backend
medusa-backend/node_modules/
medusa-backend/.git/
medusa-backend/integration-tests/
medusa-backend/.vscode/
medusa-backend/*.log
medusa-backend/.DS_Store
medusa-backend/.env
medusa-backend/.env.local
medusa-backend/.env.*.local
medusa-backend/static/
